@startuml guardias_santiago_casos_uso
left to right direction

actor "Maestre / Junta" as Admin
actor "Sargento (Encargado)" as Encargado
actor "Guardia" as Guardia
actor "Amigo de la Guardia" as Publico

rectangle "RenaceGest: Ecosistema 1521" {
  (Alta Masiva IA) as UC1
  (Validación Manual de Categoría) as UC2
  (Gestión de Secciones) as UC3
  (Solicitud de Equipo) as UC4
  (Consultar Actos y Galería) as UC5
  (Comentar y Etiquetar) as UC6
  (Donación / Inscripción QR) as UC7
}

Admin --> UC1
Admin --> UC2
Encargado --> UC3
Encargado --> UC2
Guardia --> UC4
Publico --> UC5
Publico --> UC6
Publico --> UC7

UC1 <.. UC2 : <<extend>> (Si error IA)
@enduml
