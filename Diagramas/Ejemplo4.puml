@startuml name Ejemplo4

actor Usuario
participant Estacion
participant Sistema
participant "Pasarela de pago" as Pago
participant "Técnico mantenimiento" as Tecnico

Usuario -> Estacion : Insertar bicicleta
Estacion -> Sistema : Notificar devolución

Sistema -> Estacion : Bloquear bicicleta
Estacion --> Sistema : Confirmación bloqueo

alt Bicicleta averiada
    Sistema -> Tecnico : Aviso de mantenimiento
end

Sistema -> Sistema : Calcular coste del trayecto

Sistema -> Pago : Solicitar cobro

alt Pago correcto
    Pago --> Sistema : Confirmación pago
    Sistema --> Usuario : Devolución finalizada
else Pago fallido
    Pago --> Sistema : Error en el pago
    Sistema --> Usuario : Cuenta bloqueada
end

@enduml